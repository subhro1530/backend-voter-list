PORT=4000
DATABASE_URL=postgresql://username:password@host/database?sslmode=require

# Gemini API Keys - Add multiple keys for automatic failover
# Format: GEMINI_API_KEY_1, GEMINI_API_KEY_2, etc.
# The system will automatically switch to the next key when one is exhausted
# You can add up to 20 keys (GEMINI_API_KEY_1 through GEMINI_API_KEY_20)
GEMINI_API_KEY_1=your-first-api-key-here
GEMINI_API_KEY_2=your-second-api-key-here
GEMINI_API_KEY_3=your-third-api-key-here
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=
GEMINI_API_KEY_6=
GEMINI_API_KEY_7=

# Legacy single key (used as fallback if no numbered keys are set)
# GEMINI_API_KEY=your-api-key-here

GEMINI_MODEL=gemini-2.5-flash

# Cost guard: keep paid keys disabled in AUTO mode by default.
# Set to true only when you intentionally want paid fallback in AUTO mode.
GEMINI_ALLOW_PAID_FALLBACK=false

# Optional delay (ms) between Gemini page requests to avoid rate limits
GEMINI_PAGE_DELAY_MS=2000

# CORS Origins - comma separated, NO trailing slashes
CORS_ORIGINS=http://localhost:3000,https://your-frontend-domain.com
# JWT Configuration for Authentication
# IMPORTANT: Change JWT_SECRET in production!
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Cloudinary Configuration (for voter photo uploads)
# Sign up at https://cloudinary.com to get these credentials
# If not configured, voter photos will be skipped silently
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret